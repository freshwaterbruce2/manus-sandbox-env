{
  "default": true,
  "MD001": true,  // Heading levels should only increment by one at a time
  "MD003": { "style": "atx" }, // Heading style (ATX headings preferred)
  "MD004": { "style": "dash" }, // Unordered list style (dash preferred)
  "MD005": true,  // Inconsistent indentation for list items at the same level
  "MD007": { "indent": 2 }, // Unordered list indentation
  "MD009": true,  // Trailing spaces
  "MD010": true,  // Hard tabs
  "MD011": true,  // Backslashes should be escaped
  "MD012": true,  // Multiple consecutive blank lines
  "MD013": false, // Line length (disable for flexibility in documentation)
  "MD014": true,  // Dollar signs used before commands without showing output
  "MD018": true,  // No space after hash in atx style heading
  "MD019": true,  // Multiple spaces after hash in atx style heading
  "MD022": true,  // Headings should be surrounded by blank lines
  "MD023": true,  // Headings must start at the beginning of the line
  "MD024": true,  // Multiple headings with the same content
  "MD025": true,  // Multiple top-level headings in the same document
  "MD026": true,  // Trailing punctuation in heading
  "MD027": true,  // Multiple spaces after blockquote symbol
  "MD028": true,  // Blank line inside blockquote
  "MD029": { "style": "ordered" }, // Ordered list item prefix (ordered preferred)
  "MD030": true,  // Spaces after list markers
  "MD031": true,  // Fenced code blocks should be surrounded by blank lines
  "MD032": true,  // Lists should be surrounded by blank lines
  "MD033": false, // Inline HTML (allow for GitHub flavored Markdown tables)
  "MD034": true,  // Bare URL used
  "MD035": { "style": "---" }, // Horizontal rule style (--- preferred)
  "MD036": true,  // Emphasis used instead of headings
  "MD037": true,  // Spaces inside emphasis markers
  "MD038": true,  // Spaces inside code block markers
  "MD039": true,  // Fenced code blocks should not be indented
  "MD040": true,  // Fenced code blocks should have a language specified
  "MD041": true,  // First line in file should be a top-level heading
  "MD042": true,  // No empty links
  "MD043": true,  // Required heading structure
  "MD044": { "names": ["GitHub", "CLI", "Manus", "AI", "Python", "Markdown", "Git", "PR", "API", "OS", "URL", "JSON", "HTML", "CSS", "PPT", "PPTX", "GH_TOKEN"], "code_blocks": false }, // Proper names should be capitalized
  "MD045": true,  // Images should have alternate text
  "MD046": true,  // Code block style (fenced preferred)
  "MD047": true,  // Files should end with a single blank line
  "MD048": true,  // Code fence style (backticks preferred)
  "MD049": true,  // Emphasis style should be consistent
  "MD050": true   // Strong style should be consistent
}
